<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meu Primeiro Programa</title>
    <style>
        body {
            background-color: rgb(111, 111, 182);
            color: white; /* Comentario em CSS*/
            font-family: Arial, sans-serif;
        }
        h1 {
            color: rgb(255, 239, 15);
        }

    </style>
</head>
<body>
    <h1>Olá, Mundo!</h1> <!-- Isso é um comentário -->
    <p>já me livrei da maldição!</p>
    <script>
        var n1 = Number(window.prompt("Digite um número:")) //vai perguntar o número ...
        var n2 = Number(window.prompt ("Digite outro número:")) //vai perguntar outro número ...
        var s = n1 + n2 //vai somar os números digitados
        window.alert(`A soma entre ${n1} e ${n2} é igual a ${s}`) //vai mostrar a soma dos números digitados
        // (number + number) para adição
        // (string + string) para concatenação (juntar textos)
    </script>
</body>
</html>
